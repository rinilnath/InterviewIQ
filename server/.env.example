# InterviewIQ Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── Core ────────────────────────────────────────────────────────────────────
PORT=5000
APP_URL=https://your-app.onrender.com   # public URL — used in welcome email login link
JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Payment Details (shown to users on the upgrade page) ────────────────────
# Set these to your actual payment details.
# The server reads them at runtime — they are NEVER bundled into the frontend.
# NOTE: PAYMENT_ACCOUNT_NAME is intentionally NOT sent to the frontend.
#       Money routes correctly via UPI ID / account number alone.

PAYMENT_UPI_ID=yourname@sbi
PAYMENT_ACCOUNT_NAME=Your Full Name          # kept server-side only, never exposed
PAYMENT_ACCOUNT_NUMBER=30357755849
PAYMENT_IFSC=SBIN0010316
PAYMENT_BANK_NAME=State Bank of India
PAYMENT_BANK_BRANCH=Your Branch Name
PAYMENT_SWIFT_CODE=                          # optional — for international wires (e.g. SBININBB)

# ─── Support Email (never exposed to frontend) ────────────────────────────────
# Tickets submitted by users are emailed here. Reply-To is set to the user's
# email, so you can reply directly from your inbox.
SUPPORT_EMAIL=rinilnath@gmail.com

# SMTP settings — for Gmail use an App Password (not your account password).
# Enable 2FA on Google → Security → App Passwords → create one for "Mail".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-sender@gmail.com    # Gmail address used to send (can be same as SUPPORT_EMAIL)
SMTP_PASS=xxxx-xxxx-xxxx-xxxx      # Gmail App Password
