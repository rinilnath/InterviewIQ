{
  "name": "interviewiq",
  "version": "1.0.0",
  "description": "InterviewIQ — AI-Powered Interview Management Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm install --legacy-peer-deps && npm run build && cd ../server && npm install",
    "start": "node server/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "dotenv": "^17.4.0"
  }
}
