# Server Environment Variables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=interviewiq-docs
JWT_SECRET=your-very-long-random-jwt-secret-here
JWT_EXPIRES_IN=8h
CLAUDE_API_KEY=your-anthropic-api-key
PORT=5000

# Email (Resend — https://resend.com → API Keys)
RESEND_API_KEY=your_resend_api_key
SUPPORT_EMAIL=support@yourcompany.com

# Cloudflare Turnstile (bot protection on login + registration)
# Get keys at: dash.cloudflare.com → Turnstile → Add Site
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Client Environment Variables (for Vite)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key
